    const last = parts[parts.length - 1];
    obj[last] = value;
    return result;
}
const QA_STORAGE_KEY = "qa_session_v1";
// Filter redundant options: user has text input for custom answers + skip button
function isRedundantOpt(opt) {
    const lower = opt.toLowerCase();
    return lower === "skip" || lower === "custom" || opt === "跳過" || opt === "自訂" || lower.startsWith("custom ") || opt.startsWith("自訂 ") || lower === "other" || opt === "其他";
}
/** Shared helper: triggers AI material recommendation and returns question card data */ async function fetchMaterialRecommendation(spec, lang) {
